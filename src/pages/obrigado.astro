---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
import WhatsAppCTA from '../components/ui/WhatsAppCTA.astro';
import Icon from '../components/ui/Icon.astro';
---

<Layout title="Mensagem Enviada | Rebeca Ayupe Psicóloga" noindex>
  <Header />
  <main>
    <Section bg="white">
      <div class="max-w-3xl mx-auto text-center">
        <div class="bg-purple-50 rounded-xl p-12 shadow-sm">
          <div class="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <Icon name="check" class="h-10 w-10 text-primary" label="Mensagem enviada" />
          </div>

          <h1 class="text-3xl font-bold text-gray-900 mb-4">Mensagem enviada!</h1>
          <p class="text-lg text-gray-700 mb-8">
            Obrigada por entrar em contato. Sua mensagem foi recebida e responderei o mais breve possível.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button href="/" variant="outline">Voltar para o site</Button>
            <WhatsAppCTA mensagem="geral" variant="whatsapp" label="Falar pelo WhatsApp" />
          </div>
        </div>
      </div>
    </Section>
  </main>
  <Footer />
</Layout>
