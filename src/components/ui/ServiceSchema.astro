---
import { CONFIG } from '../../config';

interface Props {
  name: string;
  description: string;
  serviceType?: string;
  url?: string;
}

const { name, description, serviceType = 'Psicoterapia', url } = Astro.props;
const fullUrl = url ?? new URL(Astro.url.pathname, CONFIG.siteUrl).toString();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name,
  description,
  serviceType,
  url: fullUrl,
  provider: {
    '@type': 'Person',
    name: CONFIG.nome,
    identifier: `CRP ${CONFIG.crp}`,
    url: CONFIG.siteUrl,
  },
  areaServed: [
    { '@type': 'City', name: CONFIG.cidade },
    { '@type': 'Country', name: 'Brasil' },
  ],
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: CONFIG.siteUrl,
    servicePhone: CONFIG.whatsapp,
  },
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
