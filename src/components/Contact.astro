---
import { CONFIG } from '../config';
import Section from './ui/Section.astro';
import Icon from './ui/Icon.astro';
import Button from './ui/Button.astro';

const whatsappHref = `https://wa.me/${CONFIG.whatsappFormatado}?text=${CONFIG.mensagens.geral}`;
const horarioSemana = CONFIG.horarioAtendimento.split(',')[1]?.trim() ?? CONFIG.horarioAtendimento;
---

<Section id="contato" bg="white">
  <div class="max-w-3xl mx-auto text-center mb-16">
    <h2 class="section-title">Entre em Contato</h2>
    <p class="section-subtitle">
      Estou disponível para esclarecer suas dúvidas e agendar sua primeira sessão
    </p>
  </div>

  <div class="flex flex-col lg:flex-row gap-12">
    <div class="lg:w-1/2">
      <div class="bg-purple-50 rounded-xl p-8 h-full">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Informações de Contato</h3>

        <div class="space-y-6">
          <div class="flex items-start">
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mr-4 shrink-0">
              <Icon name="mail" class="h-6 w-6 text-primary" />
            </div>
            <div>
              <h4 class="text-lg font-medium text-gray-900 mb-1">E-mail</h4>
              <p class="text-gray-600">{CONFIG.email}</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mr-4 shrink-0">
              <Icon name="phone" class="h-6 w-6 text-primary" />
            </div>
            <div>
              <h4 class="text-lg font-medium text-gray-900 mb-1">WhatsApp</h4>
              <p class="text-gray-600">{CONFIG.whatsappVisual}</p>
              <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="text-primary inline-flex items-center mt-2 font-medium hover:underline">
                Enviar mensagem
                <Icon name="arrow-right" class="h-5 w-5 ml-1" />
              </a>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center mr-4 shrink-0">
              <Icon name="link" class="h-6 w-6 text-primary" />
            </div>
            <div>
              <h4 class="text-lg font-medium text-gray-900 mb-1">Redes Sociais</h4>
              <a href={CONFIG.instagramUrl} target="_blank" rel="noopener noreferrer" class="text-primary inline-flex items-center font-medium hover:underline">
                @{CONFIG.instagram}
                <Icon name="arrow-right" class="h-5 w-5 ml-1" />
              </a>
            </div>
          </div>
        </div>

        <div class="mt-8">
          <h4 class="text-lg font-medium text-gray-900 mb-4">Horário de Atendimento</h4>
          <ul class="space-y-2 text-gray-600">
            <li class="flex justify-between">
              <span>Segunda a Sexta</span>
              <span>{horarioSemana}</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="lg:w-1/2">
      <div class="bg-white rounded-xl shadow-sm p-8 border border-gray-100">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">Envie uma Mensagem</h3>

        <form action="/mail.php" method="POST" accept-charset="UTF-8" class="space-y-6">
          <input type="hidden" name="redirect" value={CONFIG.siteUrl} />
          <div class="hidden" aria-hidden="true">
            <label for="company">Empresa</label>
            <input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
          </div>

          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nome Completo</label>
            <input type="text" id="name" name="name" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" placeholder="Digite seu nome completo" required />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
            <input type="email" id="email" name="email" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" placeholder="Digite seu e-mail" required />
          </div>

          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Telefone/WhatsApp</label>
            <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" placeholder="(00) 00000-0000" />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Mensagem</label>
            <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-primary" placeholder="Digite sua mensagem" required></textarea>
          </div>

          <Button type="submit" variant="primary" class="w-full">Enviar Mensagem</Button>

          <p class="text-sm text-gray-500 text-center">
            Ao enviar este formulário, seus dados serão usados apenas para retorno do contato solicitado.
          </p>
        </form>
      </div>
    </div>
  </div>
</Section>
