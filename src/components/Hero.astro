---
import { Image } from 'astro:assets';
import heroImage from '../assets/rebeca_ayupe.avif';
import WhatsAppCTA from './ui/WhatsAppCTA.astro';
---

<section id="inicio" class="py-20 md:py-32 bg-linear-to-br from-violet-50 to-white">
  <div class="container-custom">
    <div class="flex flex-col-reverse md:flex-row items-center justify-between gap-12">
      <div class="md:w-1/2">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight mb-4">
          Psicoterapia online com a <span class="text-primary">Psicóloga Rebeca Ayupe</span>
        </h1>
        <p class="text-xl text-gray-600 mb-8 max-w-lg">
          Atendimento online para adultos e adolescentes em Goiânia e em todo o Brasil. Um espaço seguro para compartilhar, compreender e transformar.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <WhatsAppCTA mensagem="geral" />
          <a
            href="#sobre"
            class="inline-flex items-center justify-center gap-2 text-primary border border-primary font-medium py-2 px-6 rounded-md transition duration-300 hover:bg-primary/5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/50 focus-visible:ring-offset-2"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M13.8 12H3" />
            </svg>
            Saiba mais
          </a>
        </div>
      </div>
      <div class="md:w-1/2">
        <Image
          src={heroImage}
          alt="Psicóloga Rebeca Ayupe Ferreira, CRP 09/20699, em ambiente acolhedor"
          widths={[400, 600, 800, 1200]}
          sizes="(min-width: 768px) 600px, 100vw"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          format="webp"
          quality={80}
          class="w-full h-auto rounded-2xl shadow-xl"
        />
      </div>
    </div>
  </div>
</section>
