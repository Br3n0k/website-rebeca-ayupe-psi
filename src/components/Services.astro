---
import Section from './ui/Section.astro';
import Card from './ui/Card.astro';
import Icon from './ui/Icon.astro';
import WhatsAppCTA from './ui/WhatsAppCTA.astro';

const servicos = [
  {
    titulo: 'Psicoterapia Individual',
    descricao: 'Atendimento online personalizado para adultos. Um espaço seguro para autoconhecimento, desenvolvimento pessoal e superação de desafios emocionais.',
    itens: ['Ansiedade e Depressão', 'Desenvolvimento Pessoal', 'Estresse e Burnout'],
    mensagem: 'depressao' as const,
    iconPath: 'M12 4.354a4 4 0 110 5.292V15a3 3 0 01-3 3H9a3 3 0 01-3-3v-5.354a4 4 0 110-5.292V5a3 3 0 013-3h3a3 3 0 013 3v.354a4 4 0 110 5.292V15a3 3 0 01-3 3h-3a3 3 0 01-3-3v-5.354',
  },
  {
    titulo: 'Atendimento para Adolescentes',
    descricao: 'Acompanhamento especializado para jovens, abordando questões emocionais específicas desta fase e promovendo saúde mental.',
    itens: ['Autoestima e Identidade', 'Relações Familiares', 'Habilidades Sociais'],
    mensagem: 'ansiedade' as const,
    iconPath: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  },
  {
    titulo: 'Orientação e Aconselhamento',
    descricao: 'Suporte para momentos específicos de decisão, transição ou crise, com foco em soluções práticas e estratégias de enfrentamento.',
    itens: ['Transições de Vida', 'Relacionamentos', 'Tomada de Decisões'],
    mensagem: 'geral' as const,
    iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
];
---

<Section id="servicos" bg="muted">
  <div class="max-w-3xl mx-auto text-center mb-16">
    <h2 class="section-title">Meus Serviços</h2>
    <p class="section-subtitle">
      Conheça as modalidades de atendimento psicológico que ofereço para ajudar no seu bem-estar emocional
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {servicos.map(({ titulo, descricao, itens, mensagem, iconPath }) => (
      <Card accent class="hover:-translate-y-1 transition-transform duration-300">
        <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconPath} />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">{titulo}</h3>
        <p class="text-gray-600 mb-4">{descricao}</p>
        <ul class="space-y-2 mb-6">
          {itens.map((item) => (
            <li class="flex items-center text-gray-700">
              <Icon name="check-circle" class="w-5 h-5 text-primary mr-2 shrink-0" />
              {item}
            </li>
          ))}
        </ul>
        <WhatsAppCTA mensagem={mensagem} variant="outline" />
      </Card>
    ))}
  </div>
</Section>
